# --- LLM runtime (Ollama) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=ministral:3b
OLLAMA_REQUEST_TIMEOUT=120
OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_TOKENS=1024

# --- Embeddings ---
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DIM=1024

# --- Vector store (Qdrant) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=legal_contracts

# --- Retrieval ---
RETRIEVAL_TOP_K=8
RETRIEVAL_DENSE_WEIGHT=0.65
RETRIEVAL_BM25_WEIGHT=0.35

# --- Ingestion ---
CHUNK_SIZE_TOKENS=900
CHUNK_OVERLAP_TOKENS=120
MAX_DOCUMENT_MB=25

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=INFO
DATA_DIR=./data
UPLOAD_DIR=./data/uploads

# --- Observability (OpenTelemetry) ---
OTEL_SERVICE_NAME=legal-ai-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_ENABLED=true
METRICS_ENABLED=true
LOG_FORMAT=text

# --- Resilience: Redis (rate limiting + ingest queue) ---
# Leave empty to use in-memory rate limiting and disable the ingest queue.
REDIS_URL=

# --- Resilience: Ollama circuit breaker ---
OLLAMA_CB_ENABLED=true
OLLAMA_CB_FAILURE_THRESHOLD=5
OLLAMA_CB_RECOVERY_TIMEOUT=30

# --- Resilience: API rate limiting (per client IP) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_QA=10/minute
RATE_LIMIT_RISK=10/minute
RATE_LIMIT_INGEST=3/minute
RATE_LIMIT_COMPARE=3/minute

# --- Resilience: async ingest queue (requires REDIS_URL + worker) ---
INGEST_ASYNC_ENABLED=false
INGEST_SYNC_FALLBACK=true
INGEST_MAX_RETRIES=2

# --- UI ---
UI_API_BASE_URL=http://localhost:8000
